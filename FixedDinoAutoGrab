-- Also scan for click detectors and touch interests when nearby (NO TELEPORT)
spawn(function()
    while task.wait(0.3) do
        local character = LocalPlayer.Character
        if not character then continue end
        
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then continue end
        
        -- Look for ClickDetectors when nearby
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("ClickDetector") then
                -- Get parent position
                local parent = obj.Parent
                if parent then
                    local position
                    if parent:IsA("Model") and parent.PrimaryPart then
                        position = parent.PrimaryPart.Position
                    elseif parent:IsA("BasePart") then
                        position = parent.Position
                    else
                        position = parent:GetPivot().Position
                    end
                    
                    -- Check if player is near (within click detector's max distance)
                    local distance = (humanoidRootPart.Position - position).Magnitude
                    if distance <= (obj.MaxActivationDistance or 32) then
                        -- Try to trigger click detector
                        local success = pcall(function()
                            obj.MouseClick:Fire()
                            StatusLabel.Text = "Status: Clicked "..parent.Name
                        end)
                    end
                end
            elseif obj:IsA("TouchTransmitter") then
                -- Touch transmitters (for parts you walk into)
                local parent = obj.Parent
                if parent and parent:IsA("BasePart") then
                    local distance = (humanoidRootPart.Position - parent.Position).Magnitude
                    if distance <= 5 then -- Within touching distance
                        StatusLabel.Text = "Status: Touching "..parent.Name
                    end
                end
            end
        end
    end
end)

