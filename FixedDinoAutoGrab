-- Animate particles
spawn(function()
    while task.wait(0.03) do
        for _, p in ipairs(particles) do
            p.posX = p.posX + p.speedX * 0.01
            p.posY = p.posY + p.speedY * 0.01

            if p.posX < 0.02 then 
                p.posX = 0.02 
                p.speedX = math.abs(p.speedX) 
            end
            
            if p.posX > 0.98 then 
                p.posX = 0.98 
                p.speedX = -math.abs(p.speedX) 
            end
            
            if p.posY < 0.02 then 
                p.posY = 0.02 
                p.speedY = math.abs(p.speedY) 
            end
            
            if p.posY > 0.98 then 
                p.posY = 0.98 
                p.speedY = -math.abs(p.speedY) 
            end

            p.frame.Position = UDim2.new(p.posX, -p.frame.AbsoluteSize.X/2, p.posY, -p.frame.AbsoluteSize.Y/2)
        end
    end
end)

-- Key press function
local function pressKey(key)
    VirtualInputManager:SendKeyEvent(true, key, false, nil)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, key, false, nil)
end

-- Check if player is near an object (distance check)
local function isNearObject(position, maxDistance)
    local character = LocalPlayer.Character
    if not character then return false end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    local distance = (rootPart.Position - position).Magnitude
    return distance <= maxDistance
end

-- Grab proximity prompts when nearby (NO TELEPORT)
local function grabProximity(prompt)
    if prompt and prompt:IsA("ProximityPrompt") then
        -- Get prompt position
        local promptPosition
        local parent = prompt.Parent
        
        if parent then
            if parent:IsA("Model") and parent.PrimaryPart then
                promptPosition = parent.PrimaryPart.Position
            elseif parent:IsA("BasePart") then
                promptPosition = parent.Position
            else
                promptPosition = parent:GetPivot().Position
            end
            
            -- Check if player is near the prompt (within activation distance)
            if isNearObject(promptPosition, prompt.MaxActivationDistance or 10) then
                -- Try to trigger the prompt
                local success, result = pcall(function()
                    prompt.HoldDuration = 0
                    
                    -- Method 1: Use fireproximityprompt if available
                    if fireproximityprompt then
                        fireproximityprompt(prompt)
                        return true
                    end
                    
                    -- Method 2: Use prompt methods
                    prompt:InputHoldBegin()
                    task.wait(0.01)
                    prompt:InputHoldEnd()
                    return true
                end)
                
                if success then
                    StatusLabel.Text = "Status: Grabbed "..prompt.Name
                    return true
                end
            end
        end
    end
    return false
end

-- Collect items when nearby (NO TELEPORT)
local function collectItems()
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            grabProximity(obj)
        elseif obj:IsA("Part") or obj:IsA("Model") then
            local nameLower = obj.Name:lower()
            if nameLower:find("item") or nameLower:find("collect") or nameLower:find("pickup") or nameLower:find("brainrot") or nameLower:find("coin") or nameLower:find("money") then
                -- Get item position
                local position
                if obj:IsA("Model") and obj.PrimaryPart then
                    position = obj.PrimaryPart.Position
                else
                    position = obj.Position
                end
                
                -- Check if player is near the item (within 10 studs)
                if isNearObject(position, 10) then
                    -- Press E to collect
                    pressKey(Enum.KeyCode.E)
                    StatusLabel.Text = "Status: Collecting "..obj.Name
                    task.wait(0.2)
                end
            end
        end
    end
end

-- Collect GUI items (fixed)
local function collectGUIItems()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return end
    
    for _, obj in pairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") and obj.Text then
            local textLower = obj.Text:lower()
            if textLower:find("collect") or textLower:find("grab") or textLower:find("pickup") or textLower:find("take") or textLower:find("claim") then
                -- Click on the button (only if visible and enabled)
                if obj.Visible and obj.Active then
                    local absPos = obj.AbsolutePosition
                    local absSize = obj.AbsoluteSize
                    
                    if absPos and absSize then
                        local centerX = absPos.X + absSize.X / 2
                        local centerY = absPos.Y + absSize.Y / 2
                        
                        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, Workspace.CurrentCamera, 1)
                        task.wait(0.05)
                        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, Workspace.CurrentCamera, 1)
                        
                        StatusLabel.Text = "Status: Clicked "..obj.Text
                    end
                end
            end
        elseif obj:IsA("ImageButton") then
            local nameLower = obj.Name:lower()
            if nameLower:find("collect") or nameLower:find("grab") or nameLower:find("pickup") then
                -- Click on the image button (only if visible and enabled)
                if obj.Visible and obj.Active then
                    local absPos = obj.AbsolutePosition
                    local absSize = obj.AbsoluteSize
                    
                    if absPos and absSize then
                        local centerX = absPos.X + absSize.X / 2
                        local centerY = absPos.Y + absSize.Y / 2
                        
                        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, Workspace.CurrentCamera, 1)
                        task.wait(0.05)
                        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, Workspace.CurrentCamera, 1)
                    end
                end
            end
        end
    end
end

