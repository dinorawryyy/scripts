-- CORE LOGIC: GHOSTING & RAKNET
-----------------------------------------------------------
local enabled = false
local ghostModel = nil

local function removeGhost()
    if ghostModel then 
        ghostModel:Destroy() 
        ghostModel = nil 
    end
end

local function createGhost()
    local char = player.Character
    if not char then return end
    
    removeGhost()
    
    ghostModel = Instance.new("Model")
    ghostModel.Name = "Dino_Visual_Freeze"
    ghostModel.Parent = workspace
    
    -- Clone parts to show where you are "stuck" for others
    for _, obj in pairs(char:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            local ghostPart = obj:Clone()
            -- Strip scripts and physics immediately to prevent lag
            for _, c in pairs(ghostPart:GetDescendants()) do
                if not c:IsA("SpecialMesh") and not c:IsA("BlockMesh") and not c:IsA("CylinderMesh") then
                    c:Destroy()
                end
            end
            
            ghostPart.Parent = ghostModel
            ghostPart.Anchored = true
            ghostPart.CanCollide = false
            ghostPart.CanTouch = false
            ghostPart.CanQuery = false
            
            -- HIGH VISIBILITY: Solid Neon Green
            ghostPart.Material = Enum.Material.Neon
            ghostPart.Color = Color3.fromRGB(0, 255, 0)
            ghostPart.Transparency = 0.2 -- Mostly solid
            
            -- Snap ghost to your exact position at toggle moment
            ghostPart.CFrame = obj.CFrame
        end
    end
end

local function updateState(newState)
    enabled = newState

    if enabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        ToggleButton.Text = "ON"
        StatusLabel.Text = "STATUS: DESYNCED"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        Outline.Color = Color3.fromRGB(0, 255, 0)
        
        -- Create the solid neon ghost
        createGhost()

        -- RAKNET: Freeze traffic to server
        -- This stops the server from knowing you are moving/animating
        pcall(function()
            if raknet and raknet.desync then 
                raknet.desync(true) 
            else
                -- High-latency fallback if raknet isn't present
                settings().Network.IncomingReplicationLag = 1000
            end
        end)
        
        -- WE DO NOT STOP HUMANOID ANIMATIONS HERE
        -- You will see yourself walk, but the server won't receive the packets.
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        ToggleButton.Text = "OFF"
        StatusLabel.Text = "STATUS: INACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        Outline.Color = Color3.fromRGB(255, 0, 0)
        
        removeGhost()

        pcall(function()
            if raknet and raknet.desync then 
                raknet.desync(false) 
            else
                settings().Network.IncomingReplicationLag = 0
            end
        end)
    end
end

ToggleButton.Activated:Connect(function()
    updateState(not enabled)
end)

player.CharacterAdded:Connect(function()
    if enabled then updateState(false) end
end)

print("[Dino DESYNC] Local-Anims Active | Server-Freeze Active")
