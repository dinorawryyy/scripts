-- SMOOTH GHOST & RAKNET SYSTEM
-----------------------------------------------------------
local enabled = false
local animConnection
local ghostModel = nil
local pulseConnection = nil

local function removeGhost()
    if ghostModel then ghostModel:Destroy() ghostModel = nil end
    if pulseConnection then pulseConnection:Disconnect() pulseConnection = nil end
end

local function createGhost()
    local char = player.Character
    if not char then return end
    
    removeGhost()
    
    ghostModel = Instance.new("Model")
    ghostModel.Name = "Dino_Ghost"
    ghostModel.Parent = workspace
    
    local ghostParts = {}

    -- Deep copy character and tools for high visibility
    for _, obj in pairs(char:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            local ghostPart = obj:Clone()
            ghostPart.Parent = ghostModel
            ghostPart.CanCollide = false
            ghostPart.CanTouch = false
            ghostPart.Anchored = true
            
            -- HIGH VISIBILITY: Neon Light Green
            ghostPart.Material = Enum.Material.Neon
            ghostPart.Color = Color3.fromRGB(50, 255, 50) 
            ghostPart.Transparency = 0.4
            ghostPart.CFrame = obj.CFrame
            
            -- Strip scripts/physics
            for _, c in pairs(ghostPart:GetChildren()) do
                if not c:IsA("SpecialMesh") and not c:IsA("BlockMesh") then
                    c:Destroy()
                end
            end
            table.insert(ghostParts, ghostPart)
        end
    end

    -- Smooth Pulse Animation
    local startTick = tick()
    pulseConnection = RunService.RenderStepped:Connect(function()
        local wave = (math.sin(tick() * 5) + 1) / 4 -- Smooth oscillation
        for _, p in pairs(ghostParts) do
            if p and p.Parent then
                p.Transparency = 0.3 + wave
            end
        end
    end)
end

local function updateState(newState)
    enabled = newState
    humanoid = getHumanoid()

    if enabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        ToggleButton.Text = "ON"
        StatusLabel.Text = "DESYNC: ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
        Outline.Color = StatusLabel.TextColor3
        
        createGhost()

        -- RAKNET DESYNC: Freezes position on server
        pcall(function()
            if raknet and raknet.desync then 
                raknet.desync(true) 
            end
        end)

        -- Stop local animations to prevent visual twitching
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do track:Stop() end
        if animConnection then animConnection:Disconnect() end
        animConnection = humanoid.AnimationPlayed:Connect(function(t) t:Stop() end)
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        ToggleButton.Text = "OFF"
        StatusLabel.Text = "DESYNC: OFF"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        Outline.Color = StatusLabel.TextColor3
        
        removeGhost()

        pcall(function()
            if raknet and raknet.desync then 
                raknet.desync(false) 
            end
        end)

        if animConnection then animConnection:Disconnect() animConnection = nil end
    end
end

ToggleButton.Activated:Connect(function()
    updateState(not enabled)
end)

player.CharacterAdded:Connect(function()
    if enabled then updateState(false) end
end)

print("[Dino DESYNC] System Loaded with Smooth Ghosting")
