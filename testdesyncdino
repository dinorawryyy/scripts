-- CORE GHOST & OPTIMIZED RAKNET LOGIC
-----------------------------------------------------------
local enabled = false
local ghostModel = nil
local animConnection

local function removeGhost()
    if ghostModel then 
        ghostModel:Destroy() 
        ghostModel = nil 
    end
end

local function createGhost()
    local char = player.Character
    if not char then return end
    
    removeGhost()
    
    ghostModel = Instance.new("Model")
    ghostModel.Name = "Dino_Visual_Freeze"
    ghostModel.Parent = workspace
    
    -- Clone character parts + Gears
    for _, obj in pairs(char:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            local ghostPart = Instance.new("Part") -- Create new parts to avoid laggy cloning of huge scripts
            ghostPart.Size = obj.Size
            ghostPart.CFrame = obj.CFrame
            ghostPart.Anchored = true
            ghostPart.CanCollide = false
            ghostPart.Parent = ghostModel
            
            -- VISIBILITY: Solid Glowing Neon Green
            ghostPart.Material = Enum.Material.Neon
            ghostPart.Color = Color3.fromRGB(0, 255, 0) -- Pure Bright Green
            ghostPart.Transparency = 0.2 -- Just enough to see your real body through it, but very solid
            
            -- Handle Head/Accessories Meshes
            if obj:IsA("MeshPart") or obj:FindFirstChildOfClass("SpecialMesh") then
                local mesh = obj:FindFirstChildOfClass("SpecialMesh") or obj:Clone()
                if mesh:IsA("MeshPart") then
                   -- Handle meshparts by cloning and stripping
                else
                   mesh:Clone().Parent = ghostPart
                end
            end
        end
    end
end

local function updateState(newState)
    enabled = newState
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")

    if enabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        ToggleButton.Text = "ON"
        StatusLabel.Text = "STATUS: DESYNCED"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        Outline.Color = Color3.fromRGB(0, 255, 0)
        
        -- Lock visual ghost
        createGhost()

        -- RAKNET HOOK (Optimized)
        pcall(function()
            if raknet and raknet.desync then 
                raknet.desync(true) 
            else
                -- Fallback for environments without raknet
                settings().Network.IncomingReplicationLag = 1000
            end
        end)

        -- Stop Anims to prevent movement lag visual
        if hum then
            for _, track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
            animConnection = hum.AnimationPlayed:Connect(function(t) t:Stop() end)
        end
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        ToggleButton.Text = "OFF"
        StatusLabel.Text = "STATUS: INACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        Outline.Color = Color3.fromRGB(255, 0, 0)
        
        removeGhost()

        pcall(function()
            if raknet and raknet.desync then 
                raknet.desync(false) 
            else
                settings().Network.IncomingReplicationLag = 0
            end
        end)

        if animConnection then animConnection:Disconnect() end
    end
end

ToggleButton.Activated:Connect(function()
    updateState(not enabled)
end)

-- Cleanup on death to prevent "Ghost Stacking"
player.CharacterAdded:Connect(function()
    if enabled then updateState(false) end
end)

