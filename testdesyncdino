-- GHOST & DESYNC LOGIC
-----------------------------------------------------------
local enabled = false
local animConnection
local ghostModel = nil

-- Function to remove the ghost
local function removeGhost()
    if ghostModel then
        ghostModel:Destroy()
        ghostModel = nil
    end
end

-- Function to create the smooth light green highlight
local function createGhost()
    local char = player.Character
    if not char then return end
    
    removeGhost() -- Clean up existing ghost
    
    ghostModel = Instance.new("Model")
    ghostModel.Name = "DesyncGhost_Dino"
    ghostModel.Parent = workspace
    
    -- Loop through character and gears
    for _, obj in pairs(char:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            local ghostPart = obj:Clone()
            ghostPart.Parent = ghostModel
            ghostPart.CanCollide = false
            ghostPart.CanTouch = false
            ghostPart.CanQuery = false
            ghostPart.Anchored = true
            
            -- Visual Styling: Light Green & Smooth
            ghostPart.Material = Enum.Material.ForceField -- Smooth neon look
            ghostPart.Color = Color3.fromRGB(144, 238, 144) -- Light Green
            ghostPart.Transparency = 0.6
            
            -- Fix CFrame to current position
            ghostPart.CFrame = obj.CFrame
            
            -- Clean up scripts/sounds/decals inside the ghost parts
            for _, child in pairs(ghostPart:GetChildren()) do
                if not child:IsA("SpecialMesh") and not child:IsA("BlockMesh") then
                    child:Destroy()
                end
            end
        end
    end
end

local function stopAnims(hum)
    if not hum then return end
    for _, track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
end

local function updateState(newState)
    enabled = newState
    humanoid = getHumanoid()

    if enabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        ToggleButton.Text = "ON"
        StatusLabel.Text = "DESYNC: ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
        Outline.Color = StatusLabel.TextColor3
        
        -- Generate Ghost at current freeze point
        createGhost()

        for _, p in ipairs(particles) do
            p.frame.BackgroundColor3 = Color3.fromRGB(math.random(150, 255), math.random(200, 255), 0)
        end

        stopAnims(humanoid)
        if animConnection then animConnection:Disconnect() end
        animConnection = humanoid.AnimationPlayed:Connect(function(t) t:Stop() end)

        local s, e = pcall(function()
            if raknet and raknet.desync then raknet.desync(true) end
        end)
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        ToggleButton.Text = "OFF"
        StatusLabel.Text = "DESYNC: OFF"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        Outline.Color = StatusLabel.TextColor3
        
        -- Clear Ghost
        removeGhost()

        for _, p in ipairs(particles) do
            p.frame.BackgroundColor3 = Color3.fromRGB(0, math.random(200, 255), 0)
        end

        if animConnection then animConnection:Disconnect() animConnection = nil end
        pcall(function()
            if raknet and raknet.desync then raknet.desync(false) end
        end)
    end
end

