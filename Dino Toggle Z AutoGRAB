    -- Update player lists
    local function updatePlayerLists()
        -- Clear existing lists
        for _, child in ipairs(PlayersScroll:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        for _, child in ipairs(WhitelistScroll:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        -- Add online players
        local players = game:GetService("Players"):GetPlayers()
        for _, player in ipairs(players) do
            if player.Name ~= Player.Name then
                local playerButton = Instance.new("TextButton")
                playerButton.Size = UDim2.new(1, 0, 0, 30)
                playerButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                playerButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                playerButton.Font = Enum.Font.Gotham
                playerButton.TextSize = 12
                playerButton.Text = player.Name
                playerButton.AutoButtonColor = false
                playerButton.Parent = PlayersScroll
                
                local playerButtonCorner = Instance.new("UICorner")
                playerButtonCorner.CornerRadius = UDim.new(0, 3)
                playerButtonCorner.Parent = playerButton
                
                playerButton.MouseButton1Click:Connect(function()
                    AddInput.Text = player.Name
                end)
            end
        end
        
        -- Add whitelisted players
        for _, whitelistedName in ipairs(WhitelistData.Whitelisted) do
            local whitelistButton = Instance.new("TextButton")
            whitelistButton.Size = UDim2.new(1, 0, 0, 30)
            whitelistButton.BackgroundColor3 = Color3.fromRGB(0, 40, 0)
            whitelistButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            whitelistButton.Font = Enum.Font.GothamBold
            whitelistButton.TextSize = 12
            whitelistButton.Text = whitelistedName
            whitelistButton.AutoButtonColor = false
            whitelistButton.Parent = WhitelistScroll
            
            local whitelistButtonCorner = Instance.new("UICorner")
            whitelistButtonCorner.CornerRadius = UDim.new(0, 3)
            whitelistButtonCorner.Parent = whitelistButton
            
            whitelistButton.MouseButton1Click:Connect(function()
                AddInput.Text = whitelistedName
            end)
        end
        
        -- Update scroll canvas sizes
        PlayersScroll.CanvasSize = UDim2.new(0, 0, 0, PlayersLayout.AbsoluteContentSize.Y)
        WhitelistScroll.CanvasSize = UDim2.new(0, 0, 0, WhitelistLayout.AbsoluteContentSize.Y)
    end
    
    -- Add player to whitelist
    AddButton.MouseButton1Click:Connect(function()
        local playerName = AddInput.Text:gsub("%s+", "")
        if playerName == "" then return end
        
        -- Check if already whitelisted
        for _, name in ipairs(WhitelistData.Whitelisted) do
            if name:lower() == playerName:lower() then
                AddInput.Text = "Already whitelisted!"
                task.wait(1)
                AddInput.Text = ""
                return
            end
        end
        
        -- Add to whitelist
        table.insert(WhitelistData.Whitelisted, playerName)
        saveWhitelist()
        updatePlayerLists()
        AddInput.Text = "Added "..playerName
        task.wait(1)
        AddInput.Text = ""
    end)
    
    -- Remove player from whitelist
    RemoveButton.MouseButton1Click:Connect(function()
        local playerName = AddInput.Text:gsub("%s+", "")
        if playerName == "" then return end
        
        -- Find and remove from whitelist
        for i, name in ipairs(WhitelistData.Whitelisted) do
            if name:lower() == playerName:lower() then
                table.remove(WhitelistData.Whitelisted, i)
                saveWhitelist()
                updatePlayerLists()
                AddInput.Text = "Removed "..playerName
                task.wait(1)
                AddInput.Text = ""
                return
            end
        end
        
        AddInput.Text = "Not in whitelist!"
        task.wait(1)
        AddInput.Text = ""
    end)
    
    -- Close whitelist manager
    CloseButton.MouseButton1Click:Connect(function()
        WhitelistFrame.Visible = false
    end)
    
    -- Toggle whitelist manager with Y key
    UIS.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == Enum.KeyCode.Y then
            WhitelistFrame.Visible = not WhitelistFrame.Visible
            if WhitelistFrame.Visible then
                updatePlayerLists()
            end
        end
    end)
    
    -- Initial update
    updatePlayerLists()
end

-- Animasyonlu parçacıklar
local particles = {}
for i = 1, 5 do
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
    particle.BackgroundColor3 = isAllowed and Color3.fromRGB(0, math.random(200, 255), 0) or Color3.fromRGB(math.random(200, 255), 50, 50)
    particle.BorderSizePixel = 0
    particle.BackgroundTransparency = math.random(50, 80)/100
    particle.Parent = MainFrame

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = particle

    particles[i] = {
        frame = particle,
        speedX = math.random(-80, 80)/100,
        speedY = math.random(-80, 80)/100,
        posX = math.random() * 0.9 + 0.05,
        posY = math.random() * 0.9 + 0.05
    }
end

-- Parçacık animasyonu
spawn(function()
    while task.wait(0.03) do
        for _, p in ipairs(particles) do
            p.posX = p.posX + p.speedX * 0.01
            p.posY = p.posY + p.speedY * 0.01

            if p.posX < 0.02 then 
                p.posX = 0.02 
                p.speedX = math.abs(p.speedX) 
            end
            
            if p.posX > 0.98 then 
                p.posX = 0.98 
                p.speedX = -math.abs(p.speedX) 
            end
            
            if p.posY < 0.02 then 
                p.posY = 0.02 
                p.speedY = math.abs(p.speedY) 
            end
            
            if p.posY > 0.98 then 
                p.posY = 0.98 
                p.speedY = -math.abs(p.speedY) 
            end

            p.frame.Position = UDim2.new(p.posX, -p.frame.AbsoluteSize.X/2, p.posY, -p.frame.AbsoluteSize.Y/2)
        end
    end
end)

