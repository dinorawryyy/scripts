-- Try to load saved whitelist
local function loadWhitelist()
    local success, data = pcall(function()
        if readfile then
            local saved = readfile("DinoScripts_Whitelist.json")
            return HttpService:JSONDecode(saved)
        end
    end)
    return success and data or WhitelistData
end

-- Save whitelist
local function saveWhitelist()
    pcall(function()
        if writefile then
            writefile("DinoScripts_Whitelist.json", HttpService:JSONEncode(WhitelistData))
        end
    end)
end

