local IsActive = false

local function toggle()
    if not isAllowed then
        StatusLabel.Text = "NOT WHITELISTED"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        Outline.Color = Color3.fromRGB(255, 50, 50)
        return
    end
    
    IsActive = not IsActive
    StatusLabel.Text = IsActive and "INSTANT E: ACTIVE" or "INSTANT E: OFF [Z]"
    StatusLabel.TextColor3 = IsActive and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(255, 255, 255)
    Outline.Color = StatusLabel.TextColor3
    
    -- Parçacık renklerini değiştir
    for _, p in ipairs(particles) do
        if IsActive then
            p.frame.BackgroundColor3 = Color3.fromRGB(math.random(150, 255), math.random(200, 255), 0)
        else
            p.frame.BackgroundColor3 = Color3.fromRGB(0, math.random(200, 255), 0)
        end
    end
end

UIS.InputBegan:Connect(function(i, p)
    if not p and i.KeyCode == Enum.KeyCode.Z then
        toggle()
    end
end)

