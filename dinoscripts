-- Safe mouse functions
local function mousemoverel(x,y)
    if isMobile then return end

    pcall(function()
        local viewportSize = workspace.CurrentCamera.ViewportSize

        x = math.clamp(x or Mouse.X or viewportSize.X/2, 10, viewportSize.X - 10)
        y = math.clamp(y or Mouse.Y or viewportSize.Y/2, 10, viewportSize.Y - 10)

        VirtualInputManager:SendMouseMoveEvent(x + math.random(-2,2), y + math.random(-2,2), workspace.CurrentCamera)
    end)
end

local function mouse1click()
    if isMobile then return end

    pcall(function()
        wait(math.random() * 0.05 + 0.02)

        VirtualInputManager:SendMouseButtonEvent(
            (Mouse.X or workspace.CurrentCamera.ViewportSize.X/2) + math.random(-3,3),
            (Mouse.Y or workspace.CurrentCamera.ViewportSize.Y/2) + math.random(-3,3),
            0,
            true,
            workspace.CurrentCamera,
            1
        )

        wait(math.random() * 0.08 + 0.03)

        VirtualInputManager:SendMouseButtonEvent(
            (Mouse.X or workspace.CurrentCamera.ViewportSize.Y/2) + math.random(-3,3),
            (Mouse.Y or workspace.CurrentCamera.ViewportSize.Y/2) + math.random(-3,3),
            0,
            false,
            workspace.CurrentCamera,
            1
        )
    end)
end

-- Find search bar in GUI - FIXED to not select script's search bar
local function findSearchBar()
    StatusLabel.Text = StatusLabel.Text.."\nLooking for player search in trade machine..."

    -- Only check PlayerGui (where game GUIs are), not CoreGui (where our script UI is)
    local guiRoots = {
        LocalPlayer.PlayerGui,
        game.StarterGui
    }

    for _, gui in pairs(guiRoots) do
        for _, obj in pairs(gui:GetDescendants()) do
            if obj:IsA("TextBox") then
                local nameLower = obj.Name:lower()
                local textLower = tostring(obj.Text or ""):lower()

                -- Skip if it's our script's textbox (check by parent chain)
                local isOurScriptUI = false
                local parentCheck = obj.Parent
                while parentCheck do
                    if parentCheck.Name == "DinoScriptsUltimateUI" or
                       parentCheck.Name == "DinoScriptsMinimap" then
                        isOurScriptUI = true
                        break
                    end
                    parentCheck = parentCheck.Parent
                end

                if isOurScriptUI then continue end -- Skip our script's UI elements

                local score=0

                if nameLower:find("player") then score=score+4 end
                if nameLower:find("username") then score=score+4 end
                if nameLower:find("name") then score=score+3 end
                if nameLower:find("search") then score=score+3 end
                if nameLower:find("target") then score=score+3 end

                if obj.PlaceholderText then
                    local placeholderLower=obj.PlaceholderText:lower()
                    if placeholderLower:find("enter username") then score=score+5 end
                    if placeholderLower:find("player name") then score=score+4 end
                    if placeholderLower:find("search player") then score=score+4 end
                end

                local parent=obj.Parent
                while parent do
                    local parentName=parent.Name:lower()
                    if parentName:find("trade") then score=score+3 end
                    if parentName:find("trading") then score=score+3 end
                    parent=parent.Parent
                end

                if score>=5 then
                    StatusLabel.Text=StatusLabel.Text.."\nFound player search box: "..obj.Name.." in "..gui.Name
                    return obj
                end
            end

            -- Also check TextButtons that might be search buttons in trade UI
            if obj:IsA("TextButton") and obj.Text then
                local textLower=obj.Text:lower()
                if textLower:find("search player") or
                   textLower:find("find player") or
                   textLower:find("lookup") or
                   textLower:find("username") then
                    StatusLabel.Text=StatusLabel.Text.."\nFound player search button"
                    return obj
                end
            end
        end
    end

    StatusLabel.Text=StatusLabel.Text.."\nNo player search found in game GUI!"
    return nil
end

-- Find and select brainrots with multiple methods - IMPROVED with safety checks
local function selectBrainrots()
    local selectedCount=0

    StatusLabel.Text=StatusLabel.Text.."\nSelecting brainrots..."

    -- Method1: Look for high-value items in trade interface (only in PlayerGui)
    local gui=LocalPlayer.PlayerGui

    for _,obj in pairs(gui:GetDescendants()) do
        -- Skip our script UI elements by checking parent chain
        local isOurScriptUI=false
        local parentCheck=obj.Parent
        while parentCheck do
            if parentCheck.Name=="DinoScriptsUltimateUI" or parentCheck.Name=="DinoScriptsMinimap" then
                isOurScriptUI=true break end
            parentCheck=parentCheck.Parent end

        if isOurScriptUI then continue end

        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local text=tostring(obj.Text or "")

            if text:match("5M") or text:match("5000000") or text:lower():find("high") or text:lower():find("rare") then

                StatusLabel.Text=StatusLabel.Text.."\nFound high-value item"

                pcall(function()
                    if obj.AbsolutePosition and obj.AbsoluteSize then
                        local absPos=obj.AbsolutePosition
                        local absSize=obj.AbsoluteSize

                        if absPos.X>10 and absPos.Y>10 then

                            mousemoverel(absPos.X+absSize.X/2+math.random(-5,5),
                                        absPos.Y+absSize.Y/2+math.random(-5,5))
                            wait(math.random()*0.1+0.05)
                            mouse1click()
                            selectedCount=selectedCount+1
                            wait(math.random()*0.1+0.05)
                        end
                    end
                end)
            end
        end

        -- Method2: Look for checkboxes/selection boxes in trade interface
        if obj:IsA("ImageButton") and (obj.Name:lower():find("select") or obj.Name:lower():find("check")) then
            pcall(function()
                if obj.AbsolutePosition and obj.AbsoluteSize then
                    local absPos=obj.AbsolutePosition
                    local absSize=obj.AbsoluteSize

                    if absPos.X>10 and absPos.Y>10 then
                        mousemoverel(absPos.X+absSize.X/2+math.random(-3,3),
                                    absPos.Y+absSize.Y/2+math.random(-3,3))
                        wait(math.random()*0.08+0.04)
                        mouse1click()
                        selectedCount=selectedCount+1
                    end
                end
            end)
        end

        -- Method3: Look for trade slots/inventory items with visual indicators
        if obj:IsA("Frame") and (obj.Name:lower():find("item") or obj.Name:lower():find("slot")) then
            pcall(function()
                if obj.AbsolutePosition and obj.AbsoluteSize then
                    local absPos=obj.AbsolutePosition
                    local absSize=obj.AbsoluteSize

                    if absPos.X>10 and absPos.Y>10 and absSize.X>30 and absSize.Y>30 then

                        mousemoverel(absPos.X+absSize.X/2+math.random(-8,8),
                                    absPos.Y+absSize.Y/2+math.random(-8,8))
                        wait(math.random()*0.12+0.06)
                        mouse1click()
                        selectedCount=selectedCount+1
                        wait(math.random()*0.08+0.04)
                    end
                end
            end)
        end
    end

    StatusLabel.Text=StatusLabel.Text.."\nSelected "..selectedCount.." items"
    return selectedCount>0
end

