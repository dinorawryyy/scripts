local function findAcceptButton()
    StatusLabel.Text=StatusLabel.Text.."\nLooking for accept button..."

    for _,obj in pairs(LocalPlayer.PlayerGui:GetDescendants()) do

        -- Skip our script UI elements by checking parent chain
        local isOurScriptUI=false
        local parentCheck=obj.Parent while parentCheck do
            if parentCheck.Name=="DinoScriptsUltimateUI" or parentCheck.Name=="DinoScriptsMinimap" then
                isOurScriptUI=true break end parentCheck=parentCheck.Parent end

        if isOurScriptUI then continue end

        if obj:IsA("TextButton") and obj.Text then
            local textLower=obj.Text:lower()

            local score=0

            if textLower:find("accept") then score=score+4 end
            if textLower:find("confirm") then score=score+4 end
            if textLower:find("trade") then score=score+3 end

            if obj.BackgroundColor3 then local r,g,b=obj.BackgroundColor3.R,obj.BackgroundColor3.G,obj.BackgroundColor3.B
                if g>r and g>b then score=score+2 end if r>g and r>b then score=score+1 end end

            if obj.AbsoluteSize and obj.AbsoluteSize.X>80 and obj.AbsoluteSize.Y>30 then score=score+2 end

            if score>=5 then
                StatusLabel.Text=StatusLabel.Text.."\nFound accept button: "..obj.Text.." (score:"..score..")"

                if obj.AbsolutePosition and obj.AbsolutePosition.X>10 and obj.AbsolutePosition.Y>10 then return obj end
            end

        end

    end

    StatusLabel.Text=StatusLabel.Text.."\nNo accept button found!"
    return nil

end

-- MANUAL SEARCH FUNCTION - FIXED to use actual mouse movement and clicks on game GUI elements only (not script UI)
local function manualSearchTrade()
    local targetName=TargetBox.Text

    if targetName=="" then StatusLabel.Text="Status: Please enter a target username!" return end

    StatusLabel.Text="Status: Starting MANUAL search for "..targetName.."\nPlease open trade machine manually"

    wait(3)

    StatusLabel.Text=StatusLabel.Text.."\nLooking for search bar in game GUI..."

    local searchBar=findSearchBar()

    if searchBar then

        pcall(function() searchBar.Text="" end) wait(0.5)

        pcall(function() searchBar.Text=targetName end)

        StatusLabel.Text=StatusLabel.Text.."\nTyped: "..targetName

        wait(1)

        VirtualInputManager:SendKeyEvent(true,Enum.KeyCode.Return,false,nil) wait(0.1)
        VirtualInputManager:SendKeyEvent(false,Enum.KeyCode.Return,false,nil)

        StatusLabel.Text=StatusLabel.Text.."\nSearching for player..."

        wait(3)

        -- Try clicking on first result/select button (only in PlayerGui)
        for _,obj in pairs(LocalPlayer.PlayerGui:GetDescendants()) do

            -- Skip our script UI elements by checking parent chain
            local isOurScriptUI=false local parentCheck=obj.Parent while parentCheck do
                if parentCheck.Name=="DinoScriptsUltimateUI" or parentCheck.Name=="DinoScriptsMinimap" then
                    isOurScriptUI=true break end parentCheck=parentCheck.Parent end

            if isOurScriptUI then continue end

            if obj:IsA("TextButton") and (obj.Text:lower():find("select") or obj.Text:lower():find(targetName:lower():sub(1,5))) then
                pcall(function()
                    local absPos=obj.AbsolutePosition local absSize=obj.AbsoluteSize

                    mousemoverel(absPos.X+absSize.X/2+math.random(-5,5),absPos.Y+absSize.Y/2+math.random(-5,5))
                    wait(0.2) mouse1click()
                    StatusLabel.Text=StatusLabel.Text.."\nSelected player from search results"
                end) break
            end
        end

        wait(2) selectBrainrots() wait(2)

        local acceptButton=findAcceptButton()

        if acceptButton then StatusLabel.Text=StatusLabel.Text.."\nClicking accept button..."

            pcall(function()
                local absPos=acceptButton.AbsolutePosition local absSize=acceptButton.AbsoluteSize

                if absPos and absSize then
                    mousemoverel(absPos.X+absSize.X/2+math.random(-8,8),absPos.Y+absSize.Y/2+math.random(-8,8))
                    wait(math.random()*0.15+0.08) mouse1click()

                    StatusLabel.Text=StatusLabel.Text.."\n✅ Trade request sent!" wait(1) mouse1click()

                    StatusLabel.Text=StatusLabel.Text.."\n✅ Trade confirmed!"
                end
            end)

        else StatusLabel.Text=StatusLabel.Text.."\n⚠ Could not find accept button"

            local viewport=workspace.CurrentCamera.ViewportSize

            local commonPositions={ {viewport.X0.5,viewport.Y0.8}, {viewport.X0.7,viewport.Y0.85}, {viewport.X0.3,viewport.Y0.85} }

            for _,pos in ipairs(commonPositions) do
                mousemoverel(pos[1]+math.random(-15,15),pos[2]+math.random(-10,10))
                wait(math.random()0.2+0.1) mouse1click() wait(math.random()0.15+0.08)

                StatusLabel.Text=StatusLabel.Text.."\nTried clicking at common position" break
            end

        end

        StatusLabel.Text=StatusLabel.Text.."\n✅ Manual trade search COMPLETE!"

    else StatusLabel.Text=StatusLabel.Text.."\n❌ No search bar found in game trade interface!"

    end

end

