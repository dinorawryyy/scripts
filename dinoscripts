            local position = obj:IsA("Part") and obj.Position or (obj.PrimaryPart and obj.PrimaryPart.Position)
            
            if position and position.Y > 3 then -- Not underground
                -- Trade machine detection scoring system
                local score = 0
                
                -- Exact match bonus
                if name:find("trade machine") then score = score + 20 end
                if name:find("trading machine") then score = score + 15 end
                if name:find("exchange machine") then score = score + 12 end
                
                -- Partial matches
                if name:find("trade") and name:find("machine") then score = score + 10 end
                if name:find("trade") then score = score + 8 end
                if name:find("trading") then score = score + 7 end
                if name:find("exchange") then score = score + 6 end
                
                -- Avoid shops and robux
                if name:find("shop") then score = score - 15 end
                if name:find("robux") then score = score - 15 end
                if name:find("store") then score = score - 12 end
                if name:find("buy") then score = score - 8 end
                if name:find("sell") then score = score - 8 end
                if name:find("cash") then score = score - 5 end
                if name:find("money") then score = score - 5 end
                
                -- Visual indicators
                if obj:IsA("Part") then
                    if obj.BrickColor.Name:lower():find("green") then score = score + 5 end
                    if obj.Material == Enum.Material.Neon then score = score + 4 end
                    if obj.Transparency < 0.5 then score = score + 2 end
                end
                
                -- Check for proximity to player
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local playerPos = LocalPlayer.Character.HumanoidRootPart.Position
                    local dist = (position - playerPos).Magnitude
                    if dist < 100 then score = score + 5 end -- Bonus for nearby machines
                end
                
                if score > 5 then -- Minimum score threshold
                    table.insert(machinesFound, {
                        object = obj,
                        score = score,
                        position = position,
                        name = obj.Name
                    })
                end
            end
        end
    end

    -- Sort by score (highest first)
    table.sort(machinesFound, function(a,b) return a.score > b.score end)

    if #machinesFound > 0 then
        StatusLabel.Text = "Status: Found "..#machinesFound.." TRADE machines"
        -- Debug info about found machines
        for i=1, math.min(#machinesFound, 3) do
            StatusLabel.Text = StatusLabel.Text.."\n-"..machinesFound[i].name.." (score: "..machinesFound[i].score..")"
        end
        return machinesFound[1].object, machinesFound[1].position
    end

    StatusLabel.Text = "Status: No TRADE machine found!"
    return nil, nil
end

-- FIXED: Safe mouse functions that don't crash the game
local mousemoverel_safe_attempts = {}
local mouse1click_safe_attempts = {}

local function mousemoverel(x,y)
    if isMobile then return end

    -- Track attempts to prevent spam crashes
    local now = tick()
    mousemoverel_safe_attempts[now] = true

    -- Clean old attempts (older than 1 second)
    for attemptTime in pairs(mousemoverel_safe_attempts) do
        if now - attemptTime > 1 then
            mousemoverel_safe_attempts[attemptTime] = nil
        end
    end

    -- Limit to max 10 attempts per second to prevent crashes
    local count = 0
    for _ in pairs(mousemoverel_safe_attempts) do count = count + 1 end
    if count > 10 then
        wait(0.1)
        return
    end

    -- SAFE mouse movement with error handling
    pcall(function()
        -- Use ViewportPoint instead of AbsolutePosition for safer coordinates
        local viewportSize = workspace.CurrentCamera.ViewportSize

        -- Ensure coordinates are within bounds to prevent crashes
        x = math.clamp(x or Mouse.X or viewportSize.X/2, 10, viewportSize.X - 10)
        y = math.clamp(y or Mouse.Y or viewportSize.Y/2, 10, viewportSize.Y - 10)

        VirtualInputManager:SendMouseMoveEvent(x + math.random(-2,2), y + math.random(-2,2), workspace.CurrentCamera)
    end)
end

local function mouse1click()
    if isMobile then return end

    -- Track attempts to prevent spam crashes
    local now = tick()
    mouse1click_safe_attempts[now] = true

    -- Clean old attempts (older than 1 second)
    for attemptTime in pairs(mouse1click_safe_attempts) do
        if now - attemptTime > 1 then
            mouse1click_safe_attempts[attemptTime] = nil
        end
    end

    -- Limit to max 5 clicks per second to prevent crashes
    local count = 0
    for _ in pairs(mouse1click_safe_attempts) do count = count + 1 end
    if count > 5 then
        wait(0.2)
        return
    end

    -- SAFE mouse click with error handling and delays to prevent crashes
    pcall(function()
        wait(math.random() * 0.05 + 0.02) -- Random small delay to prevent rapid clicks

        -- Send press event with random position offset to avoid exact coordinates that might crash
        local xOffset,yOffset=math.random(-3,3),math.random(-3,3)

        VirtualInputManager:SendMouseButtonEvent(
            (Mouse.X or workspace.CurrentCamera.ViewportSize.X/2) + xOffset,
            (Mouse.Y or workspace.CurrentCamera.ViewportSize.Y/2) + yOffset,
            0,
            true,
            workspace.CurrentCamera,
            1
        )

        wait(math.random() * 0.08 + 0.03) -- Random release delay

        VirtualInputManager:SendMouseButtonEvent(
            (Mouse.X or workspace.CurrentCamera.ViewportSize.Y/2) + xOffset,
            (Mouse.Y or workspace.CurrentCamera.ViewportSize.Y/2) + yOffset,
            0,
            false,
            workspace.CurrentCamera,
            1
        )
    end)
end

-- Find search bar in GUI with advanced detection for trade machine search
local function findSearchBar()
    StatusLabel.Text = StatusLabel.Text.."\nLooking for player search in trade machine..."

    local guiRoots = {
        LocalPlayer.PlayerGui,
        game.CoreGui,
        game.StarterGui
    }

    for _, gui in pairs(guiRoots) do
        for _, obj in pairs(gui:GetDescendants()) do
            if obj:IsA("TextBox") then
                local nameLower = obj.Name:lower()
                local textLower = tostring(obj.Text or ""):lower()

                -- Check for player search indicators in trade machine context
                local score=0

                if nameLower:find("player") then score=score+4 end
                if nameLower:find("username") then score=score+4 end
                if nameLower:find("name") then score=score+3 end
                if nameLower:find("search") then score=score+3 end
                if nameLower:find("target") then score=score+3 end

                -- Check placeholder text for search indicators
                if obj.PlaceholderText then
                    local placeholderLower=obj.PlaceholderText:lower()
                    if placeholderLower:find("enter username") then score=score+5 end
                    if placeholderLower:find("player name") then score=score+4 end
                    if placeholderLower:find("search player") then score=score+4 end
                    if placeholderLower:find("target player") then score=score+4 end
                end

                -- Also check parent frame/container names
                local parent=obj.Parent
                while parent do
                    local parentName=parent.Name:lower()
                    if parentName:find("trade") then score=score+3 end
                    if parentName:find("trading") then score=score+3 end
                    parent=parent.Parent
                end

                if score>=5 then
                    StatusLabel.Text=StatusLabel.Text.."\nFound player search box: "..obj.Name
                    return obj
                end
            end

            -- Also check TextButtons that might be search buttons in trade UI
            if obj:IsA("TextButton") and obj.Text then
                local textLower=obj.Text:lower()
                if textLower:find("search player") or
                   textLower:find("find player") or
                   textLower:find("lookup") or
                   textLower:find("username") then
                    StatusLabel.Text=StatusLabel.Text.."\nFound player search button"
                    return obj
                end
            end
        end
    end

    StatusLabel.Text=StatusLabel.Text.."\nNo player search found! Will attempt manual entry..."
    return nil
end

-- Find and select brainrots with multiple methods - IMPROVED with safety checks
local function selectBrainrots()
    local selectedCount=0

    StatusLabel.Text=StatusLabel.Text.."\nSelecting brainrots..."

    -- Method1: Look for high-value items in trade interface
    local gui=LocalPlayer.PlayerGui

    -- First find the trade GUI container
    local tradeContainer=nil
    for _,obj in pairs(gui:GetDescendants()) do
        if obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
            local nameLower=obj.Name:lower()
            if nameLower:find("trade") or
               nameLower:find("inventory") or
               nameLower:find("items") or
               nameLower:find("selection") then
                tradeContainer=obj
                break
            end
        end
    end

    -- Search within trade container or entire GUI
    local searchRoot=tradeContainer or gui

    for _,obj in pairs(searchRoot:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local text=tostring(obj.Text or "")

            -- Advanced pattern matching for brainrots with safety checks
            if text:match("5M") or
               text:match("5[,.]?%d*[Mm]") or
               text:match("5000000") or
               text:match("%+") or
               text:lower():find("high") or
               text:lower():find("valuable") or
               text:lower():find("rare") or
               text:lower():find("expensive") then

                StatusLabel.Text=StatusLabel.Text.."\nFound high-value item"

                -- SAFE clicking with position validation
                pcall(function()
                    if obj.AbsolutePosition and obj.AbsoluteSize then
                        local absPos=obj.AbsolutePosition
                        local absSize=obj.AbsoluteSize

                        if absPos.X>10 and absPos.Y>10 and
                           absSize.X>10 and absSize.Y>10 then

                            mousemoverel(absPos.X+absSize.X/2+math.random(-5,5),
                                        absPos.Y+absSize.Y/2+math.random(-5,5))
                            wait(math.random()*0.1+0.05)
                            mouse1click()
                            selectedCount=selectedCount+1
                            wait(math.random()*0.1+0.05) -- Delay between clicks
                        end
                    end
                end)
            end
        end

        -- Method2: Look for checkboxes/selection boxes in trade interface
        if obj:IsA("ImageButton") and (obj.Name:lower():find("select") or
                                       obj.Name:lower():find("check") or
                                       obj.Name:lower():find("item")) then
            pcall(function()
                if obj.AbsolutePosition and obj.AbsoluteSize then
                    local absPos=obj.AbsolutePosition
                    local absSize=obj.AbsoluteSize

                    if absPos.X>10 and absPos.Y>10 then
                        mousemoverel(absPos.X+absSize.X/2+math.random(-3,3),
                                    absPos.Y+absSize.Y/2+math.random(-3,3))
                        wait(math.random()*0.08+0.04)
                        mouse1click()
                        selectedCount=selectedCount+1
                    end
                end
            end)
        end

        -- Method3: Look for trade slots/inventory items with visual indicators
        if obj:IsA("Frame") and (obj.Name:lower():find("item") or
                                 obj.Name:lower():find("slot") or
                                 obj.Name:lower():find("brainrot")) then
            pcall(function()
                if obj.AbsolutePosition and obj.AbsoluteSize then
                    local absPos=obj.AbsolutePosition
                    local absSize=obj.AbsoluteSize

                    if absPos.X>10 and absPos.Y>10 and
                       absSize.X>30 and absSize.Y>30 then -- Minimum size check

                        mousemoverel(absPos.X+absSize.X/2+math.random(-8,8),
                                    absPos.Y+absSize.Y/2+math.random(-8,8))
                        wait(math.random()*0.12+0.06)
                        mouse1click()
                        selectedCount=selectedCount+1
                        wait(math.random()*0.08+0.04) -- Delay between selections
                    end
                end
            end)
        end
    end

    -- Method4: Select random items if no high-value found (with safety)
    if selectedCount < 3 then
        StatusLabel.Text=StatusLabel.Text.."\nSelecting random items..."
        
        local framesFound={}
        for _,obj in pairs(gui:GetDescendants()) do
            if obj:IsA("Frame") and obj.AbsoluteSize and 
               obj.AbsoluteSize.X>40 and obj.AbsoluteSize.Y>40 and -- Larger minimum size
               obj.AbsolutePosition and
               obj.AbsolutePosition.X>20 and obj.AbsolutePosition.Y>20 then
                table.insert(framesFound,obj)
            end
        end

        -- Select up to 5 random frames with safety delays
        for i=1,math.min(5,#framesFound) do
            pcall(function()
                local frame=framesFound[i]
                local absPos=frame.AbsolutePosition
                local absSize=frame.AbsoluteSize

                mousemoverel(absPos.X+absSize.X/2+math.random(-10,10),
                            absPos.Y+absSize.Y/2+math.random(-10,10))
                wait(math.random()*0.15+0.08)
                mouse1click()
                selectedCount=selectedCount+1
                wait(math.random()*0.12+0.06) -- Delay between random selections
            end)
        end
    end

    StatusLabel.Text=StatusLabel.Text.."\nSelected "..selectedCount.." items"
    return selectedCount>0
end

-- Find accept/confirm button in trade GUI with safety checks
local function findAcceptButton()
    StatusLabel.Text=StatusLabel.Text.."\nLooking for accept button..."

    local guiRoots={LocalPlayer.PlayerGui}

    for _,gui in pairs(guiRoots) do
        for _,obj in pairs(gui:GetDescendants()) do
            if obj:IsA("TextButton") and obj.Text then
                local textLower=obj.Text:lower()

                -- Check for accept/confirm/trade related text with scoring system
                local score=0

                if textLower:find("accept") then score=score+4 end
                if textLower:find("confirm") then score=score+4 end
                if textLower:find("trade") then score=score+3 end
                if textLower:find("send") then score=score+2 end
                if textLower:find("ok") then score=score+1 end
                if textLower:find("yes") then score=score+1 end

                -- Check button color/style (accept buttons are often green/red prominent buttons)
                if obj.BackgroundColor3 then
                    local r,g,b=obj.BackgroundColor3.R,obj.BackgroundColor3.G,obj.BackgroundColor3.B
                    if g>r and g>b then score=score+2 end -- Green button bonus (accept)
                    if r>g and r>b then score=score+1 end -- Red button (often cancel/decline)
                end

                -- Check size (accept buttons are usually large/prominent)
                if obj.AbsoluteSize and obj.AbsoluteSize.X>80 and obj.AbsoluteSize.Y>30 then
                    score=score+2 end

                if score>=5 then -- Higher threshold for safety
                    StatusLabel.Text=StatusLabel.Text.."\nFound accept button: "..obj.Text.." (score:"..score..")"

                    -- Verify position is clickable (not off-screen)
                    if obj.AbsolutePosition and
                       obj.AbsolutePosition.X>10 and
                       obj.AbsolutePosition.Y>10 then
                        return obj
                    end
                end
            end
        end
    end

    StatusLabel.Text=StatusLabel.Text.."\nNo accept button found!"
    return nil
end

