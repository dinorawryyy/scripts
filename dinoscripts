-- Animate particles
spawn(function()
    while true do
        for _, p in ipairs(particles) do
            p.posX = p.posX + p.speedX * 0.008
            p.posY = p.posY + p.speedY * 0.008

            -- Bounce off edges
            if p.posX < 0.02 then p.posX = 0.02 p.speedX = math.abs(p.speedX) end
            if p.posX > 0.98 then p.posX = 0.98 p.speedX = -math.abs(p.speedX) end
            if p.posY < 0.02 then p.posY = 0.02 p.speedY = math.abs(p.speedY) end
            if p.posY > 0.98 then p.posY = 0.98 p.speedY = -math.abs(p.speedY) end

            p.frame.Position = UDim2.new(p.posX, -p.frame.AbsoluteSize.X/2, p.posY, -p.frame.AbsoluteSize.Y/2)

            -- Size animation
            local currentSize = p.frame.Size.X.Offset
            local newSize = math.max(1, math.min(8, currentSize + p.sizeSpeed))
            p.frame.Size = UDim2.new(0, newSize, 0, newSize)

            if newSize <= 1 or newSize >= 8 then
                p.sizeSpeed = -p.sizeSpeed
            end

            -- Fade animation
            local targetTransparency = math.random(30, 90)/100
            TweenService:Create(p.frame, TweenInfo.new(0.5), {BackgroundTransparency = targetTransparency}):Play()
        end
        wait(0.03)
    end
end)

