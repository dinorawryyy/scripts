-- FIXED: Advanced walk function with pathfinding simulation
local function walkToPosition(position)
    local character = LocalPlayer.Character
    if not character then return false end

    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")

    if not humanoid or not rootPart then return false end

    local startPos = rootPart.Position
    local distance = (position - startPos).Magnitude

    if distance < 10 then
        StatusLabel.Text = StatusLabel.Text.."\nAlready close to position"
        return true
    end

    StatusLabel.Text = StatusLabel.Text.."\nWalking to position..."
    
    humanoid:MoveTo(position)
    
    local stepStartTime = tick()
    while (rootPart.Position - position).Magnitude > 8 do
        if tick() - stepStartTime > 3 then break end -- Timeout per step
        wait(0.1)
    end

    if (rootPart.Position - position).Magnitude <= 15 then
        StatusLabel.Text = StatusLabel.Text.."\nReached position"
        return true
    else
        StatusLabel.Text = StatusLabel.Text.."\nFailed to reach position"
        return false
    end
end

