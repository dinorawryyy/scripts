-- Auto Grab Logic
local autoGrabEnabled = false
local ProximityPromptService = game:GetService("ProximityPromptService")

-- Function to grab everything instantly
local function grabAllProximity()
    if not autoGrabEnabled then return end

    -- Find all proximity prompts in workspace
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            -- Instant grab
            pcall(function()
                if fireproximityprompt then
                    fireproximityprompt(obj)
                else
                    obj.HoldDuration = 0
                    obj:InputHoldBegin()
                    obj:InputHoldEnd()
                end
            end)
        end

        -- Also grab any interactable parts/models
        if obj:IsA("Part") or obj:IsA("Model") then
            local nameLower = obj.Name:lower()
            if nameLower:find("item") or nameLower:find("collect") or nameLower:find("pickup") or nameLower:find("brainrot") then
                -- Try to interact with it
                pcall(function()
                    local char = LocalPlayer.Character
                    if char then
                        local rootPart = char:FindFirstChild("HumanoidRootPart")
                        if rootPart then
                            rootPart.CFrame = CFrame.new(obj.Position + Vector3.new(0, 3, 0))
                            wait(0.1)
                            pressKey(Enum.KeyCode.E)
                        end
                    end
                end)
            end
        end
    end

    -- Look for GUI items to grab
    for _, gui in pairs({LocalPlayer.PlayerGui}) do
        for _, obj in pairs(gui:GetDescendants()) do
            if obj:IsA("TextButton") and obj.Text then
                local textLower = obj.Text:lower()
                if textLower:find("collect") or textLower:find("grab") or textLower:find("pickup") or textLower:find("take") then
                    pcall(function()
                        mouse1click()
                    end)
                end
            end
        end
    end
end

-- Safe mouse click function
local function mouse1click()
    if isMobile then return end

    pcall(function()
        wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(
            math.random(100, 500),
            math.random(100, 500),
            0,
            true,
            Workspace.CurrentCamera,
            1
        )
        wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(
            math.random(100, 500),
            math.random(100, 500),
            0,
            false,
            Workspace.CurrentCamera,
            1
        )
    end)
end

-- Key press function
local function pressKey(key)
    if isMobile then return end

    pcall(function()
        VirtualInputManager:SendKeyEvent(true, key, false, nil)
        wait(0.05)
        VirtualInputManager:SendKeyEvent(false, key, false, nil)
    end)
end

