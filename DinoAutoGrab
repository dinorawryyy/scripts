-- DinoScripts Auto Grab Executor
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local ProximityPromptService = game:GetService("ProximityPromptService")

-- UI Creation
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "DinoScriptsAutoGrab"
ScreenGui.Parent = game.CoreGui

-- Small rectangular UI frame
local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 200, 0, 60)
MainFrame.Position = UDim2.new(0.05, 0, 0.05, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
MainFrame.BorderSizePixel = 0
MainFrame.ClipsDescendants = true
MainFrame.Parent = ScreenGui

-- Green outline
local Outline = Instance.new("UIStroke")
Outline.Color = Color3.fromRGB(0, 255, 0)
Outline.Thickness = 2
Outline.Parent = MainFrame

-- Corner rounding
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = MainFrame

-- Title label
local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, -10, 0, 25)
Title.Position = UDim2.new(0, 5, 0, 5)
Title.BackgroundTransparency = 1
Title.Text = "DINO AUTOGrab"
Title.TextColor3 = Color3.fromRGB(0, 255, 0)
Title.Font = Enum.Font.GothamBlack
Title.TextSize = 16
Title.TextXAlignment = Enum.TextXAlignment.Left
Title.Parent = MainFrame

-- Status label
local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(1, -10, 0, 30)
StatusLabel.Position = UDim2.new(0, 5, 0, 30)
StatusLabel.BackgroundTransparency = 1
StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
StatusLabel.Font = Enum.Font.Gotham
StatusLabel.TextSize = 12
StatusLabel.TextXAlignment = Enum.TextXAlignment.Left
StatusLabel.TextYAlignment = Enum.TextYAlignment.Top
StatusLabel.Text = "Status: Auto Grab Running..."
StatusLabel.Parent = MainFrame

-- Simple particles
local particles = {}
for i = 1, 5 do
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
    particle.BackgroundColor3 = Color3.fromRGB(0, math.random(200, 255), 0)
    particle.BorderSizePixel = 0
    particle.BackgroundTransparency = math.random(50, 80)/100
    particle.Parent = MainFrame

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = particle

    particles[i] = {
        frame = particle,
        speedX = math.random(-80, 80)/100,
        speedY = math.random(-80, 80)/100,
        posX = math.random() * 0.9 + 0.05,
        posY = math.random() * 0.9 + 0.05
    }
end

-- Animate particles
spawn(function()
    while true do
        for _, p in ipairs(particles) do
            p.posX = p.posX + p.speedX * 0.01
            p.posY = p.posY + p.speedY * 0.01

            if p.posX  0.98 then p.posX = 0.98 p.speedX = -math.abs(p.speedX) end
if p.posY  0.98 then p.posY = 0.98 p.speedY = -math.abs(p.speedY) end

            p.frame.Position = UDim2.new(p.posX, -p.frame.AbsoluteSize.X/2, p.posY, -p.frame.AbsoluteSize.Y/2)
        end
        wait(0.03)
    end
end)

-- Key press function
local function pressKey(key)
    VirtualInputManager:SendKeyEvent(true, key, false, nil)
    wait(0.05)
    VirtualInputManager:SendKeyEvent(false, key, false, nil)
end

-- Mouse click function
local function mouse1click()
    VirtualInputManager:SendMouseButtonEvent(
        math.random(100, 500),
        math.random(100, 500),
        0,
        true,
        Workspace.CurrentCamera,
        1
    )
    wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(
        math.random(100, 500),
        math.random(100, 500),
        0,
        false,
        Workspace.CurrentCamera,
        1
    )
end

-- Grab proximity prompts instantly
local function grabProximity(prompt)
    if prompt and prompt:IsA("ProximityPrompt") then
        prompt.HoldDuration = 0
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegin()
            prompt:InputHoldEnd()
        end
        StatusLabel.Text = "Status: Grabbed "..prompt.Name
    end
end

-- Collect all items in workspace
local function collectItems()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            grabProximity(obj)
        elseif obj:IsA("Part") or obj:IsA("Model") then
            local nameLower = obj.Name:lower()
            if nameLower:find("item") or nameLower:find("collect") or nameLower:find("pickup") or nameLower:find("brainrot") then
                local character = LocalPlayer.Character
                if character then
                    local rootPart = character:FindFirstChild("HumanoidRootPart")
                    if rootPart then
                        rootPart.CFrame = CFrame.new(obj.Position + Vector3.new(0, 3, 0))
                        wait(0.1)
                        pressKey(Enum.KeyCode.E)
                    end
                end
            end
        end
    end
end

-- Collect GUI items
local function collectGUIItems()
    for _, gui in pairs({LocalPlayer.PlayerGui}) do
        for _, obj in pairs(gui:GetDescendants()) do
            if obj:IsA("TextButton") and obj.Text then
                local textLower = obj.Text:lower()
                if textLower:find("collect") or textLower:find("grab") or textLower:find("pickup") or textLower:find("take") then
                    mouse1click()
                end
            end
        end
    end
end

-- Main auto grab loop (automatically starts when script executes)
spawn(function()
    while true do
        StatusLabel.Text = "Status: Scanning for items..."

        -- Method 1: Collect proximity prompts
        collectItems()

        -- Method 2: Collect GUI items
        collectGUIItems()

        -- Method 3: Listen for new proximity prompts
        ProximityPromptService.PromptShown:Connect(function(prompt)
            grabProximity(prompt)
        end)

        StatusLabel.Text = "Status: Auto Grab Running..."
        wait(0.5) -- Scan every 0.5 seconds
    end
end)

print("[DinoScripts] Auto Grab executor running!")
