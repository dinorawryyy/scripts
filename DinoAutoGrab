-- Collect all items in workspace (fixed)
local function collectItems()
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            grabProximity(obj)
        elseif obj:IsA("Part") or obj:IsA("Model") then
            local nameLower = obj.Name:lower()
            if nameLower:find("item") or nameLower:find("collect") or nameLower:find("pickup") or nameLower:find("brainrot") or nameLower:find("coin") or nameLower:find("money") then
                -- Teleport to item
                local position
                if obj:IsA("Model") and obj.PrimaryPart then
                    position = obj.PrimaryPart.Position
                else
                    position = obj.Position
                end
                
                rootPart.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
                task.wait(0.1)
                pressKey(Enum.KeyCode.E)
                
                -- Also try to click on it
                local screenPos = Workspace.CurrentCamera:WorldToScreenPoint(position)
                if screenPos.Z > 0 then
                    mouse1click(screenPos.X, screenPos.Y)
                end
            end
        end
    end
end

-- Collect GUI items (fixed)
local function collectGUIItems()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return end
    
    for _, obj in pairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") and obj.Text then
            local textLower = obj.Text:lower()
            if textLower:find("collect") or textLower:find("grab") or textLower:find("pickup") or textLower:find("take") or textLower:find("claim") then
                -- Click on the button
                local absPos = obj.AbsolutePosition
                local absSize = obj.AbsoluteSize
                
                if absPos and absSize then
                    local centerX = absPos.X + absSize.X / 2
                    local centerY = absPos.Y + absSize.Y / 2
                    mouse1click(centerX, centerY)
                end
            end
        elseif obj:IsA("ImageButton") then
            local nameLower = obj.Name:lower()
            if nameLower:find("collect") or nameLower:find("grab") or nameLower:find("pickup") then
                -- Click on the image button
                local absPos = obj.AbsolutePosition
                local absSize = obj.AbsoluteSize
                
                if absPos and absSize then
                    local centerX = absPos.X + absSize.X / 2
                    local centerY = absPos.Y + absSize.Y / 2
                    mouse1click(centerX, centerY)
                end
            end
        end
    end
end

