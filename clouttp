-- ==================== FLASH STEAL LOGIC ====================
local function trackPrompt(prm)
    local hold = false
    local s40, s60, s91 = false, false, false

    prm.PromptButtonHoldBegan:Connect(function()
        if prm.ActionText ~= "Steal" then return end
        hold = true; s40 = false; s60 = false; s91 = false
        flashStatusLbl.Text = "STEALING..."
        TweenService:Create(flashStatusLbl, TweenInfo.new(0.15), {TextColor3 = NEON_TEAL}):Play()

        task.spawn(function()
            local start = tick()
            while hold do
                local p = (tick() - start) / prm.HoldDuration
                TweenService:Create(Bar, TweenInfo.new(0.04), {Size = UDim2.new(math.clamp(p,0,1),0,1,0)}):Play()
                local tool = FindTool("flash")

                if p >= 0.4 and p < 0.6 and not s40 then
                    s40 = true
                    if tool then
                        Player.Character.Humanoid:EquipTool(tool)
                        task.wait(0.15)
                        Player.Character.Humanoid:UnequipTools()
                    end
                end
                if p >= 0.6 and p < 0.91 and not s60 then
                    s60 = true
                    task.spawn(function()
                        pressKey(Enum.KeyCode.Q); task.wait(0.6); pressKey(Enum.KeyCode.Q)
                        task.wait(1);             pressKey(Enum.KeyCode.Q); pressKey(Enum.KeyCode.G)
                        task.wait(2.5);           pressKey(Enum.KeyCode.Q); pressKey(Enum.KeyCode.G)
                    end)
                end
                if p >= 0.91 and not s91 then
                    s91 = true
                    if tool then
                        Player.Character.Humanoid:EquipTool(tool)
                        task.wait(0.01)
                        tool:Activate()
                        VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true,  game, 1)
                        VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1)
                    end
                end
                RunService.RenderStepped:Wait()
            end
        end)
    end)

    prm.PromptButtonHoldEnded:Connect(function()
        hold = false
        TweenService:Create(Bar, TweenInfo.new(0.2), {Size = UDim2.new(0,0,1,0)}):Play()
        flashStatusLbl.Text = "WAITING STEAL"
        TweenService:Create(flashStatusLbl, TweenInfo.new(0.15), {TextColor3 = TEXT_BRIGHT}):Play()
        local ch = Player.Character
        if ch and ch:FindFirstChild("Humanoid") then ch.Humanoid:UnequipTools() end
    end)
end

