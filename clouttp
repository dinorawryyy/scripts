local function MakeBtn(parent, txt, w, h, smallFont)
    local b = Instance.new("TextButton", parent)
    b.Size             = UDim2.new(w or 1, 0, 0, h or 34)
    b.BackgroundColor3 = BTN_BASE
    b.Text             = txt
    b.TextColor3       = TEXT_BRIGHT
    b.Font             = smallFont and Enum.Font.Gotham or Enum.Font.GothamBlack
    b.TextSize         = smallFont and 9 or 11
    b.AutoButtonColor  = false
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 9)
    Stroke(b)
    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = BTN_HOVER}):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = BTN_BASE}):Play()
    end)
    return b
end

