local function Stroke(parent, color, thick)
    local s = Instance.new("UIStroke", parent)
    s.Color     = color or NEON_TEAL
    s.Thickness = thick or 1.8
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end

