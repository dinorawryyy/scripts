-- ==================== CORE LOGIC ====================
local function PerformPosTP(p, a)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    local hum = Player.Character and Player.Character:FindFirstChild("Humanoid")
    if not (hrp and hum) then return end
    local c = FindTool("flying")
    if c then hum:EquipTool(c); task.wait(0.1) end
    hrp.Velocity  = Vector3.new(0,0,0)
    hrp.CFrame    = CFrame.new(p)
    task.wait(0.1)
    workspace.CurrentCamera.CFrame = CFrame.new(Player.Character.Head.Position, a)
    task.delay(0.5, function() if hum then hum:UnequipTools() end end)
end

local function GetNearestPoint(petPos)
    local base = (petPos.Z > Z_THRESHOLD) and AimLocations.Right or AimLocations.Left
    local target, minD = nil, math.huge
    for _, floor in ipairs({base.FirstFloor, base.SecondFloor, base.ThirdFloor}) do
        for _, pt in ipairs(floor) do
            local d = (petPos - pt.pos).Magnitude
            if d < minD then minD = d; target = pt end
        end
    end
    return target
end

local function SpamTeleportBtn()
    local t0 = tick()
    while tick() - t0 < 2.0 do
        local gui = Player.PlayerGui:FindFirstChild("ToolsFrames")
        local btn = gui and gui:FindFirstChild("QuantumCloner") and
                    gui.QuantumCloner:FindFirstChild("TeleportToClone")
        if btn then forceClick(btn) end
        task.wait(0.05)
    end
end

function GetBestPetData()
    local deb = workspace:FindFirstChild("Debris")
    if not deb then return nil end
    local best = {val = -1, pos = nil, name = ""}
    for _, t in ipairs(deb:GetChildren()) do
        if t.Name == "FastOverheadTemplate" then
            local sGui = t:FindFirstChildOfClass("SurfaceGui")
            if sGui and sGui.Adornee then
                local gen = sGui:FindFirstChild("Generation", true)
                if gen and gen:IsA("TextLabel") and gen.Text ~= "" then
                    local v = ParseValue(gen.Text)
                    if v >= MIN_PET_VALUE then
                        local petPos = sGui.Adornee.Position - Vector3.new(0,6,0)
                        if not IsPetOnMyPlot(petPos) and v > best.val then
                            local dn = sGui:FindFirstChild("DisplayName", true)
                            best = { val = v, pos = petPos, name = (dn and dn.Text) or "Pet" }
                        end
                    end
                end
            end
        end
    end
    return best.val ~= -1 and best or nil
end

local function ExecuteCloner(floorKey, lockedPetPos)
    local isRight   = not lockedPetPos or (lockedPetPos.Z > Z_THRESHOLD)
    local routeSet  = isRight and Routes.Right or Routes.Left
    local d         = routeSet[floorKey]
    local ch        = Player.Character
    local hrp       = ch and ch:FindFirstChild("HumanoidRootPart")
    local hum       = ch and ch:FindFirstChild("Humanoid")
    if not (hrp and hum) then return end

    hum:ChangeState(Enum.HumanoidStateType.Jumping); task.wait(0.2)
    local c = FindTool("flying"); local q = FindTool("quantum")
    if c then hum:EquipTool(c); task.wait(0.1) end

    local angleY = 0
    if isRight then angleY = (floorKey == "Floor1") and 260 or 180
    else            angleY = (floorKey == "Floor1") and 260 or 0 end
    local inv       = CFrame.Angles(0, math.rad(angleY), 0)
    local stepDelay = (floorKey == "Floor3") and 0.2 or 0.1

    for _, p in ipairs(d.path) do
        hrp.Velocity = Vector3.new(0,0,0)
        hrp.CFrame   = CFrame.new(p) * inv
        task.wait(stepDelay)
    end
    hrp.CFrame = CFrame.new(d.base) * inv; task.wait(0.4)

    if q then
        hum:EquipTool(q); task.wait(0.3)
        local s = tick()
        while tick() - s < 0.6 do q:Activate(); task.wait(0.04) end
        task.spawn(SpamTeleportBtn)
        task.wait(1.0)
        hrp.CFrame = hrp.CFrame * CFrame.new(0,0,-3); task.wait(0.5)
    end

    hum:UnequipTools(); task.wait(0.1)

    local targetData
    if lockedPetPos then
        targetData = GetNearestPoint(lockedPetPos)
    else
        local bp = GetBestPetData()
        if bp then targetData = GetNearestPoint(bp.pos) end
    end
    if targetData then PerformPosTP(targetData.pos, targetData.aim) end
end

local function TpToBest()
    local p = GetBestPetData()
    if p then
        local fl = "Floor1"
        if p.pos.Y > 22 then fl = "Floor3" elseif p.pos.Y > 5 then fl = "Floor2" end
        ExecuteCloner(fl, p.pos)
    else
        TweenService:Create(BrainrotLabel, TweenInfo.new(0.2), {TextColor3 = MAC_RED}):Play()
        BrainrotLabel.Text = "NO TARGET FOUND"
        task.delay(2.5, function()
            BrainrotLabel.Text = "SCANNING..."
            TweenService:Create(BrainrotLabel, TweenInfo.new(0.2), {TextColor3 = NEON_TEAL}):Play()
        end)
    end
end

