    minimizeBtn.MouseEnter:Connect(function()
        TweenService:Create(minimizeBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(255, 210, 100)}):Play()
    end)
    minimizeBtn.MouseLeave:Connect(function()
        TweenService:Create(minimizeBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(255, 189, 46)}):Play()
    end)
    minimizeBtn.MouseButton1Click:Connect(function()
        cfg.Visible = false
        SaveConfig()
        PopOut(win)
    end)

    MakeDraggable(win, hdr)
    win:GetPropertyChangedSignal("Position"):Connect(function()
        cfg.Pos = { win.Position.X.Scale, win.Position.X.Offset,
                    win.Position.Y.Scale, win.Position.Y.Offset }
        SaveConfig()
    end)

    -- Scrolling content
    local sf = Instance.new("ScrollingFrame", win)
    sf.Name               = "Content"
    sf.Size               = UDim2.new(1,-14,1,-44)
    sf.Position           = UDim2.new(0,7,0,40)
    sf.BackgroundTransparency = 1
    sf.ScrollBarThickness = 2
    sf.ScrollBarImageColor3 = NEON_TEAL
    sf.CanvasSize         = UDim2.new(0,0,0,0)
    local layout = Instance.new("UIListLayout", sf)
    layout.SortOrder            = Enum.SortOrder.LayoutOrder
    layout.Padding              = UDim.new(0,6)
    layout.HorizontalAlignment  = Enum.HorizontalAlignment.Center
    layout.Changed:Connect(function()
        sf.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 12)
    end)

    local function OpenWin()
        cfg.Visible = true
        SaveConfig()
        PopIn(win, sizeUD, defPosUD)
    end

    return win, sf, OpenWin
